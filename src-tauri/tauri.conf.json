{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Alita",
  "version": "0.27.0",
  "identifier": "com.alita.ai-workbench",
  "build": {
    "beforeDevCommand": "npm run frontend:dev",
    "beforeBuildCommand": "npm run frontend:build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Alita",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 680,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "externalBin": ["binaries/alita-agent-sidecar"],
    "resources": {
      "resources/llama-cpp": "llama-cpp"
    },
    "icon": []
  }
}
