{
  "name": "alita",
  "private": true,
  "version": "0.26.0",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build",
    "check:desktop-prereqs": "powershell -ExecutionPolicy Bypass -File scripts/check-windows-tauri-prereqs.ps1",
    "sidecar:dev": "python -m uvicorn agent_service.app:app --host 127.0.0.1 --port 8765",
    "llama:install": "powershell -ExecutionPolicy Bypass -File scripts/install-llama-cpp.ps1",
    "desktop:dev": "powershell -ExecutionPolicy Bypass -File scripts/dev-desktop.ps1",
    "desktop:build": "powershell -ExecutionPolicy Bypass -File scripts/build-windows-app.ps1",
    "frontend:dev": "vite",
    "frontend:build": "tsc && vite build",
    "frontend:test": "vitest run",
    "frontend:lint": "tsc --noEmit"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@xyflow/react": "12.10.2",
    "clsx": "2.1.1",
    "photoswipe": "^5.4.4",
    "plyr": "^3.8.4",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.4.1",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.11.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "typescript": "6.0.3",
    "vite": "8.0.11",
    "vitest": "4.1.5"
  }
